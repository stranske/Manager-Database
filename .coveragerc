[run]
# CI invokes pytest-cov with --cov=. when no src/ directory exists. Keep the
# hard coverage gate focused on product/runtime modules rather than test,
# workflow-helper, and generated browser-bundle surfaces.
source =
    .
omit =
    .github/*
    tests/*
    scripts/*
    tools/__init__.py
    tools/ci_failure_triage.py
    tools/coverage_guard.py
    tools/coverage_trend.py
    tools/embedding_provider.py
    tools/langchain_client.py
    tools/llm_provider.py
    tools/llm_registry.py
    tools/post_ci_summary.py
    tools/registry.py
    tools/run_contract.py
    web/*
    setup.py
